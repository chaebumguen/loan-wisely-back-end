<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ccksy.loan.domain.product.mapper.LoanProductMapper">

    <select id="selectProductById" parameterType="long" resultType="java.util.HashMap">
        <![CDATA[
        SELECT *
        FROM LOAN_PRODUCT
        WHERE product_id = #{productId}
        ]]>
    </select>

    <select id="selectActiveProducts" resultType="java.util.HashMap">
        <![CDATA[
        SELECT *
        FROM LOAN_PRODUCT
        WHERE end_date IS NULL OR end_date > SYSDATE
        ]]>
    </select>

    <select id="selectProductsByIds" parameterType="map" resultType="java.util.HashMap">
        <![CDATA[
        SELECT *
        FROM LOAN_PRODUCT
        WHERE product_id IN
        ]]>
        <foreach item="id" collection="productIds" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

</mapper>
