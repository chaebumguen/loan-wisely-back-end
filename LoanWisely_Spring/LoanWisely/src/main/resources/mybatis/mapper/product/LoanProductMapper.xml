<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ccksy.loan.domain.product.mapper.LoanProductMapper">

    <!-- =========================
         Result Mapping
         ========================= -->

    <resultMap id="LoanProductResponseMap"
               type="com.ccksy.loan.domain.product.dto.response.LoanProductResponse">

        <id property="productId" column="product_id"/>
        <result property="productName" column="product_name"/>
        <result property="bankName" column="bank_name"/>
        <result property="interestRate" column="interest_rate"/>
        <result property="maxLimit" column="max_limit"/>
        <result property="loanType" column="loan_type"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <!-- =========================
         대출 상품 목록 조회 (페이징)
         ========================= -->
    <select id="selectProducts"
            resultMap="LoanProductResponseMap">

        SELECT
            product_id,
            product_name,
            bank_name,
            interest_rate,
            max_limit,
            loan_type,
            created_at
        FROM loan_product
        ORDER BY created_at DESC
        LIMIT #{size}
        OFFSET #{offset}

    </select>

    <!-- =========================
         대출 상품 전체 건수 조회
         ========================= -->
    <select id="countProducts"
            resultType="long">

        SELECT COUNT(*)
        FROM loan_product

    </select>

    <!-- =========================
         대출 상품 단건 조회
         ========================= -->
    <select id="selectProductById"
            resultMap="LoanProductResponseMap">

        SELECT
            product_id,
            product_name,
            bank_name,
            interest_rate,
            max_limit,
            loan_type,
            created_at
        FROM loan_product
        WHERE product_id = #{productId}

    </select>

</mapper>
