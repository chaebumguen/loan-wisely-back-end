<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ccksy.loan.domain.admin.rawfile.mapper.EdaStatResultMapper">

    <select id="selectNextId" resultType="long">
        SELECT EDA_STAT_RESULT_SEQ.NEXTVAL FROM dual
    </select>

    <insert id="insert" parameterType="com.ccksy.loan.domain.admin.rawfile.entity.EdaStatResult">
        INSERT INTO EDA_STAT_RESULT (
            stat_id,
            eda_run_id,
            row_id,
            column_code,
            mean,
            median,
            std,
            min,
            max,
            q1,
            q3,
            skewness,
            kurtosis,
            missing_rate,
            data_type
        ) VALUES (
            #{statId},
            #{edaRunId},
            #{rowId},
            #{columnCode},
            #{mean},
            #{median},
            #{std},
            #{min},
            #{max},
            #{q1},
            #{q3},
            #{skewness},
            #{kurtosis},
            #{missingRate},
            #{dataType}
        )
    </insert>

</mapper>
