<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ccksy.loan.domain.admin.rawfile.mapper.RawFileCellMapper">

    <insert id="insertBatch">
        INSERT INTO RAW_FILE_CELL (
            cell_id,
            upload_id,
            row_num,
            column_name,
            column_value,
            created_at
        )
        SELECT
            RAW_FILE_CELL_SEQ.NEXTVAL,
            t.upload_id,
            t.row_num,
            t.column_name,
            t.column_value,
            t.created_at
        FROM (
            <foreach collection="cells" item="cell" separator="UNION ALL">
                SELECT
                    #{cell.uploadId} AS upload_id,
                    #{cell.rowNum} AS row_num,
                    #{cell.columnName} AS column_name,
                    #{cell.columnValue} AS column_value,
                    #{cell.createdAt} AS created_at
                FROM dual
            </foreach>
        ) t
    </insert>

    <select id="selectByUploadId" parameterType="long" resultMap="RawFileCellResultMap">
        SELECT
            cell_id,
            upload_id,
            row_num,
            column_name,
            column_value,
            created_at
          FROM RAW_FILE_CELL
         WHERE upload_id = #{uploadId}
         ORDER BY row_num ASC, cell_id ASC
    </select>

    <resultMap id="RawFileCellResultMap" type="com.ccksy.loan.domain.admin.rawfile.entity.RawFileCell">
        <id     property="cellId"     column="cell_id"/>
        <result property="uploadId"   column="upload_id"/>
        <result property="rowNum"     column="row_num"/>
        <result property="columnName" column="column_name"/>
        <result property="columnValue" column="column_value"/>
        <result property="createdAt"  column="created_at"/>
    </resultMap>

    <delete id="deleteByUploadId" parameterType="long">
        DELETE FROM RAW_FILE_CELL WHERE upload_id = #{uploadId}
    </delete>

</mapper>
