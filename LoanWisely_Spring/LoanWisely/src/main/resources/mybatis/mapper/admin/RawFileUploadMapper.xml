<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ccksy.loan.domain.admin.rawfile.mapper.RawFileUploadMapper">

    <resultMap id="RawFileUploadResultMap" type="com.ccksy.loan.domain.admin.rawfile.entity.RawFileUpload">
        <id     property="uploadId"   column="upload_id"/>
        <result property="fileName"   column="file_name"/>
        <result property="fileHash"   column="file_hash"/>
        <result property="uploaderId" column="uploader_id"/>
        <result property="storedPath" column="stored_path"/>
        <result property="status"     column="status"/>
        <result property="uploadedAt" column="uploaded_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.ccksy.loan.domain.admin.rawfile.entity.RawFileUpload">
        INSERT INTO RAW_FILE_UPLOAD (
            upload_id,
            file_name,
            file_hash,
            uploader_id,
            stored_path,
            status,
            uploaded_at
        ) VALUES (
            #{uploadId},
            #{fileName},
            #{fileHash},
            #{uploaderId},
            #{storedPath},
            #{status},
            #{uploadedAt}
        )
    </insert>

    <select id="selectNextId" resultType="long">
        SELECT RAW_FILE_UPLOAD_SEQ.NEXTVAL FROM dual
    </select>

    <select id="selectById" parameterType="long" resultMap="RawFileUploadResultMap">
        SELECT *
          FROM RAW_FILE_UPLOAD
         WHERE upload_id = #{uploadId}
    </select>

    <select id="selectAll" resultMap="RawFileUploadResultMap">
        SELECT *
          FROM RAW_FILE_UPLOAD
         ORDER BY uploaded_at DESC, upload_id DESC
    </select>

    <update id="updateStatus">
        UPDATE RAW_FILE_UPLOAD
           SET status = #{status}
         WHERE upload_id = #{uploadId}
    </update>

</mapper>
