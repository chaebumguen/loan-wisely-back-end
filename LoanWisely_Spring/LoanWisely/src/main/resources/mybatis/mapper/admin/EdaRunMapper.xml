<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ccksy.loan.domain.admin.rawfile.mapper.EdaRunMapper">

    <select id="selectNextId" resultType="long">
        SELECT EDA_RUN_SEQ.NEXTVAL FROM dual
    </select>

    <insert id="insert" parameterType="com.ccksy.loan.domain.admin.rawfile.entity.EdaRun">
        INSERT INTO EDA_RUN (
            eda_run_id,
            user_id,
            snapshot_id,
            version_id,
            created_at
        ) VALUES (
            #{edaRunId},
            #{userId},
            #{snapshotId},
            #{versionId},
            #{createdAt}
        )
    </insert>

</mapper>
