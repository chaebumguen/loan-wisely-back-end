<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ccksy.loan.domain.metadata.mapper.FinancialMetaVersionMapper">

    <resultMap id="FinancialMetaVersionResultMap" type="com.ccksy.loan.domain.metadata.entity.FinancialMetaVersion">
        <id     property="versionId"   column="version_id"/>
        <result property="versionLabel" column="version_label"/>
        <result property="metaJson"    column="meta_json"/>
        <result property="status"      column="status"/>
        <result property="approvedAt"  column="approved_at"/>
        <result property="approvedBy"  column="approved_by"/>
        <result property="isActive"    column="is_active"/>
        <result property="createdAt"   column="created_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.ccksy.loan.domain.metadata.entity.FinancialMetaVersion">
        INSERT INTO FINANCIAL_META_VERSION (
            version_id,
            version_label,
            meta_json,
            status,
            approved_at,
            approved_by,
            is_active,
            created_at
        ) VALUES (
            #{versionId},
            #{versionLabel},
            #{metaJson},
            #{status},
            #{approvedAt},
            #{approvedBy},
            #{isActive},
            #{createdAt}
        )
    </insert>

    <select id="selectNextId" resultType="long">
        SELECT FINANCIAL_META_VERSION_SEQ.NEXTVAL FROM dual
    </select>

    <select id="selectById" parameterType="long" resultMap="FinancialMetaVersionResultMap">
        SELECT *
          FROM FINANCIAL_META_VERSION
         WHERE version_id = #{versionId}
    </select>

    <select id="selectActive" resultMap="FinancialMetaVersionResultMap">
        SELECT *
          FROM FINANCIAL_META_VERSION
         WHERE is_active = 'Y'
           AND status = 'APPROVED'
         ORDER BY approved_at DESC, version_id DESC
         FETCH FIRST 1 ROWS ONLY
    </select>

    <select id="selectAll" resultMap="FinancialMetaVersionResultMap">
        SELECT *
          FROM FINANCIAL_META_VERSION
         ORDER BY created_at DESC, version_id DESC
    </select>

    <update id="updateStatus">
        UPDATE FINANCIAL_META_VERSION
           SET status = #{status},
               approved_by = #{approvedBy},
               approved_at = #{approvedAt},
               is_active = #{isActive}
         WHERE version_id = #{versionId}
    </update>

    <update id="deactivateAll">
        UPDATE FINANCIAL_META_VERSION
           SET is_active = 'N'
         WHERE is_active = 'Y'
    </update>

</mapper>
