<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ccksy.loan.domain.engine.mapper.FeatureMapper">

    <!-- EN_AF_001: 빌드 결과 저장 -->
    <insert id="insertFeatureSnapshot" parameterType="map">
        <![CDATA[
        INSERT INTO FEATURE_SNAPSHOT (
            snapshot_id,
            user_id,
            version_ids_json,
            features_json_path,
            created_at
        ) VALUES (
            #{snapshotId},
            #{userId},
            #{versionIdsJson},
            #{featuresJsonPath},
            SYSTIMESTAMP
        )
        ]]>
    </insert>

    <!-- EN_AF_002: 조회 -->
    <select id="selectFeatureSnapshotById" parameterType="string" resultType="java.util.HashMap">
        <![CDATA[
        SELECT *
        FROM FEATURE_SNAPSHOT
        WHERE snapshot_id = #{snapshotId}
        ]]>
    </select>

    <!-- EN_AF_003: 스키마(선택) -->
    <select id="selectActiveFeatureSchema" resultType="java.util.HashMap">
        <![CDATA[
        SELECT *
        FROM FEATURE_SCHEMA
        WHERE is_active = 'Y'
        ORDER BY created_at DESC
        FETCH FIRST 1 ROWS ONLY
        ]]>
    </select>

</mapper>
