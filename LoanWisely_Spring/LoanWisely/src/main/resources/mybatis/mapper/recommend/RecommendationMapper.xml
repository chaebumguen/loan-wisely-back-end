<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ccksy.loan.domain.recommend.mapper.RecommendationMapper">

    <!-- EN_RE_001: 추천 결과 헤더 저장 -->
    <insert id="insertRecommendationResult" parameterType="map">
        <![CDATA[
        INSERT INTO RECO_RESULT (
            result_id,
            user_id,
            version_ids_json,
            policy_id,
            policy_version,
            created_at,
            explanation_json_path
        ) VALUES (
            #{recommendationId},
            #{userId},
            #{versionIdsJson},
            #{policyId},
            #{policyVersion},
            SYSTIMESTAMP,
            #{explanationJsonPath}
        )
        ]]>
    </insert>

    <!-- EN_RE_001: 추천 아이템 저장 -->
    <insert id="insertRecommendationItem" parameterType="map">
        <![CDATA[
        INSERT INTO RECO_ITEM (
            item_id,
            result_id,
            product_id,
            rank,
            score_value,
            estimated_rate,
            estimated_limit,
            reason_json_path
        ) VALUES (
            #{itemId},
            #{recommendationId},
            #{productId},
            #{rank},
            #{scoreValue},
            #{estimatedRate},
            #{estimatedLimit},
            #{reasonJsonPath}
        )
        ]]>
    </insert>

    <!-- EN_RE_002: 내 추천 목록 (page/size) -->
    <select id="selectMyRecommendationsPage" parameterType="map" resultType="java.util.HashMap">
        <![CDATA[
        SELECT
            result_id,
            user_id,
            policy_version,
            created_at
        FROM RECO_RESULT
        WHERE user_id = #{userId}
        ORDER BY created_at DESC
        OFFSET #{offset} ROWS FETCH NEXT #{size} ROWS ONLY
        ]]>
    </select>

    <!-- EN_RE_003: 추천 상세(헤더) -->
    <select id="selectRecommendationHeaderById" parameterType="string" resultType="java.util.HashMap">
        <![CDATA[
        SELECT *
        FROM RECO_RESULT
        WHERE result_id = #{recommendationId}
        ]]>
    </select>

    <!-- EN_RE_003: 추천 상세(아이템) -->
    <select id="selectRecommendationItemsByResultId" parameterType="string" resultType="java.util.HashMap">
        <![CDATA[
        SELECT *
        FROM RECO_ITEM
        WHERE result_id = #{recommendationId}
        ORDER BY rank ASC
        ]]>
    </select>

    <!-- (선택) 제외사유 -->
    <select id="selectExclusionReasonsByResultId" parameterType="string" resultType="java.util.HashMap">
        <![CDATA[
        SELECT *
        FROM RECO_EXCLUSION_REASON
        WHERE result_id = #{recommendationId}
        ]]>
    </select>

</mapper>
