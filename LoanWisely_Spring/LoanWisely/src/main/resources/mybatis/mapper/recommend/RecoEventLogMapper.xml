<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ccksy.loan.domain.recommend.mapper.RecoEventLogMapper">

    <resultMap id="RecoEventLogResultMap" type="com.ccksy.loan.domain.recommend.entity.RecoEventLog">
        <id     property="logId"       column="log_id"/>
        <result property="maskedUserId" column="masked_user_id"/>
        <result property="productId"   column="product_id"/>
        <result property="eventTypeCodeValueId" column="event_type_code_value_id"/>
        <result property="occurredAt"  column="occurred_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.ccksy.loan.domain.recommend.entity.RecoEventLog">
        INSERT INTO RECO_EVENT_LOG (
            log_id,
            masked_user_id,
            product_id,
            event_type_code_value_id,
            occurred_at
        ) VALUES (
            RECO_EVENT_LOG_SEQ.NEXTVAL,
            #{maskedUserId},
            #{productId},
            #{eventTypeCodeValueId},
            #{occurredAt}
        )
    </insert>

    <select id="selectByProductId" parameterType="long" resultMap="RecoEventLogResultMap">
        SELECT *
          FROM RECO_EVENT_LOG
         WHERE product_id = #{productId}
         ORDER BY occurred_at DESC, log_id DESC
    </select>

</mapper>
