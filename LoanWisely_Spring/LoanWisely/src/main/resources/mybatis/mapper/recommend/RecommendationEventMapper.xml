<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ccksy.loan.domain.recommend.mapper.RecommendationEventMapper">

    <!-- EN_RN_001: 추천 이벤트 로그 -->
    <insert id="insertRecommendationEvent" parameterType="map">
        <![CDATA[
        INSERT INTO RECO_EVENT_LOG (
            event_id,
            recommendation_id,
            event_type,
            created_at
        ) VALUES (
            #{eventId},
            #{recommendationId},
            #{eventType},
            SYSTIMESTAMP
        )
        ]]>
    </insert>

</mapper>
