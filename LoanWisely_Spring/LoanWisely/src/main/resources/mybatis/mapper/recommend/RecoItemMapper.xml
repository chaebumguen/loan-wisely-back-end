<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ccksy.loan.domain.recommend.mapper.RecoItemMapper">

    <resultMap id="RecoItemResultMap" type="com.ccksy.loan.domain.recommend.entity.RecoItem">
        <id     property="itemId"        column="item_id"/>
        <result property="resultId"      column="result_id"/>
        <result property="productId"     column="product_id"/>
        <result property="matchingScore" column="matching_score"/>
        <result property="estimatedRate" column="estimated_rate"/>
        <result property="estimatedLimit" column="estimated_limit"/>
        <result property="stabilityScore" column="stability_score"/>
        <result property="reasonJsonPath" column="reason_json_path"/>
        <result property="rank"          column="rank"/>
        <result property="createdAt"     column="created_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.ccksy.loan.domain.recommend.entity.RecoItem">
        INSERT INTO RECO_ITEM (
            item_id,
            result_id,
            product_id,
            matching_score,
            estimated_rate,
            estimated_limit,
            stability_score,
            reason_json_path,
            rank,
            created_at
        ) VALUES (
            RECO_ITEM_SEQ.NEXTVAL,
            #{resultId},
            #{productId},
            #{matchingScore},
            #{estimatedRate},
            #{estimatedLimit},
            #{stabilityScore},
            #{reasonJsonPath},
            #{rank},
            #{createdAt}
        )
    </insert>

    <select id="selectCurrentId" resultType="long">
        SELECT RECO_ITEM_SEQ.CURRVAL FROM dual
    </select>

    <select id="selectById" parameterType="long" resultMap="RecoItemResultMap">
        SELECT *
          FROM RECO_ITEM
         WHERE item_id = #{itemId}
    </select>

    <select id="selectByResultId" parameterType="long" resultMap="RecoItemResultMap">
        SELECT *
          FROM RECO_ITEM
         WHERE result_id = #{resultId}
         ORDER BY rank ASC, item_id ASC
    </select>

</mapper>
